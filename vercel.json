{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "sw.js", "use": "@vercel/static" },
    { "src": "manifest.json", "use": "@vercel/static" },
    { "src": "survey.html", "use": "@vercel/static" },
    { "src": "logo.jpeg", "use": "@vercel/static" },
    { "src": "logo-padded.png", "use": "@vercel/static" },
    { "src": "logo-icon.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/logo.jpeg", "headers": { "Cache-Control": "public, max-age=31536000" }, "dest": "/logo.jpeg" },
    { "src": "/logo-padded.png", "headers": { "Cache-Control": "public, max-age=31536000" }, "dest": "/logo-padded.png" },
    { "src": "/logo-icon.html", "dest": "/logo-icon.html" },
    { "src": "/sw.js", "headers": { "Content-Type": "application/javascript", "Cache-Control": "no-cache" }, "dest": "/sw.js" },
    { "src": "/manifest.json", "headers": { "Content-Type": "application/manifest+json" }, "dest": "/manifest.json" },
    { "src": "/survey(\\.html)?", "dest": "/survey.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
